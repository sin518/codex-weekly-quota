{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Weekly Quota",
  "version": "0.1.2",
  "identifier": "com.sin.codexweeklyquota",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "quota-overlay",
        "title": "Codex Weekly Quota",
        "width": 300,
        "height": 64,
        "minWidth": 300,
        "minHeight": 64,
        "maxWidth": 300,
        "maxHeight": 64,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "Codex Weekly Quota 设置",
        "width": 380,
        "height": 320,
        "minWidth": 380,
        "minHeight": 320,
        "maxWidth": 380,
        "maxHeight": 320,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "V6zTcKUAWXlTiUz1y4e2+SgT1NT7RGthb74LplgsV88=",
      "endpoints": [
        "https://github.com/sin518/codex-weekly-quota/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
